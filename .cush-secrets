schema = 1

[defaults]
target_vault = "cush"
target_item = "{project}"
field_template = "{key}"

[secrets]
ANTHROPIC_API_KEY = { ref = "op://cush/trendlab/anthropic_api_key", target_vault = "cush", target_item = "trendlab" }
LASTFM_API_KEY = { ref = "op://cush/trendlab/lastfm_api_key", target_vault = "cush", target_item = "trendlab" }
TRENDLAB_SECRET_PHRASE = { ref = "op://cush/trendlab/trendlab_secret_phrase", target_vault = "cush", target_item = "trendlab" }

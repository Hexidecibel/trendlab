schema = 1

[defaults]
target_vault = "cush"
target_item = "{project}"
field_template = "{key}"

[secrets]
ANTHROPIC_API_KEY = { ref = "inf://dev/trendlab/ANTHROPIC_API_KEY", target_vault = "cush", target_item = "trendlab" }
LASTFM_API_KEY = { ref = "inf://dev/trendlab/LASTFM_API_KEY", target_vault = "cush", target_item = "trendlab" }
TRENDLAB_SECRET_PHRASE = { ref = "inf://dev/trendlab/TRENDLAB_SECRET_PHRASE", target_vault = "cush", target_item = "trendlab" }

# cush-tools — auto-loads secrets from 1Password via bin/inject
# Refreshes .env from 1Password on cd, then exports values into shell.
# Requires direnv (https://direnv.net) — `direnv allow` in this dir to enable.
if command -v /home/hexi/local/src/cush-tools/bin/inject >/dev/null; then
  /home/hexi/local/src/cush-tools/bin/inject --no-prompt 2>/dev/null || true
fi
[ -f .env ] && dotenv
